# Evaluation API keys (template — copy to evaluation/.env.local and fill in).
# Never commit .env.local.
#
# Supported live path: write keys below into evaluation/.env.local, then:
#   $env:EVAL_LIVE = "1"
#   java -cp <test+runtime> rs.etf.sqltranslator.evaluation.EvaluationMain \
#        --live-gemini|--live-composer --corpus parrot-diverse [--limit N]
#
# EvaluationMain overlays missing keys from .env.local (getenv wins if already set).
# No separate PowerShell export of the file contents is required.

# Google AI Studio / Gemini API key (GeminiAdapter)
GEMINI_API_KEY=

# Cursor Dashboard → Integrations (Composer 2.5 SDK / composer_transpile.py)
CURSOR_API_KEY=

# Optional: set to 1 only when regenerating live fixtures (never in CI)
# EVAL_LIVE=1
