# Evaluation API keys (template — copy to .env.local and fill in).
# Never commit .env.local. Adapters read these from the process environment.
#
# PowerShell (current session):
#   Get-Content evaluation/.env.local | ForEach-Object {
#     if ($_ -match '^\s*#' -or $_ -match '^\s*$') { return }
#     $k, $v = $_ -split '=', 2
#     Set-Item -Path "Env:$($k.Trim())" -Value $v.Trim()
#   }
#
# Then run live eval with:
#   $env:EVAL_LIVE = "1"

# Google AI Studio / Gemini API key (GeminiAdapter)
GEMINI_API_KEY=

# Cursor Dashboard → Integrations (Composer 2.5 SDK / composer_transpile.py)
CURSOR_API_KEY=

# Optional: set to 1 only when regenerating live fixtures (never in CI)
# EVAL_LIVE=1
